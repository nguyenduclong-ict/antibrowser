{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-sidecar-template",
  "version": "0.1.0",
  "identifier": "com.admin.tauri-sidecar-template",
  "build": {
    "beforeDevCommand": "npm run vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "antibrowsers - Antidetect Browser Controller",
        "width": 1280,
        "height": 800,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/sidecar/**/*"
    ]
  }
}
