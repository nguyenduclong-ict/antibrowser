{
  "name": "antibrowsers",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tauri dev",
    "vite": "concurrently \"vite\" \"npm run sidecar:watch\"",
    "build:frontend": "tsc && vite build",
    "preview": "tauri preview",
    "tauri": "tauri",
    "sidecar:build": "npm --prefix sidecar/nodejs run build",
    "sidecar:watch": "npm --prefix sidecar/nodejs run watch",
    "build:exe": "npm run sidecar:build && npm run build:frontend && tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "axios": "^1.16.1",
    "lucide-react": "^1.16.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
